{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mythos.local/schemas/next_pass_packet.schema.json",
  "title": "NextPassPacket",
  "type": "object",
  "required": [
    "schema_version",
    "objective_id",
    "run_id",
    "branch_id",
    "pass_id",
    "objective",
    "evidence",
    "trusted_facts",
    "active_hypotheses",
    "contradictions",
    "recurring_failure_patterns",
    "candidate_actions",
    "verifier_findings",
    "open_questions",
    "raw_drilldown_refs",
    "halt_signals",
    "sources"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.1.0" },
    "objective_id": { "type": "string" },
    "run_id": { "type": "string" },
    "branch_id": { "type": "string" },
    "pass_id": { "type": "string" },
    "objective": { "type": "string" },
    "evidence": {
      "type": "array",
      "items": { "$ref": "#/$defs/evidenceRecord" }
    },
    "trusted_facts": {
      "type": "array",
      "items": { "$ref": "#/$defs/compiledFact" }
    },
    "active_hypotheses": {
      "type": "array",
      "items": { "$ref": "#/$defs/hypothesis" }
    },
    "contradictions": {
      "type": "array",
      "items": { "$ref": "#/$defs/contradiction" }
    },
    "recurring_failure_patterns": {
      "type": "array",
      "items": { "$ref": "#/$defs/recurringFailurePattern" }
    },
    "candidate_actions": {
      "type": "array",
      "items": { "$ref": "#/$defs/candidateAction" }
    },
    "verifier_findings": {
      "type": "array",
      "items": { "$ref": "#/$defs/verifierFinding" }
    },
    "open_questions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "raw_drilldown_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/sourceRef" }
    },
    "halt_signals": {
      "type": "array",
      "items": { "$ref": "#/$defs/haltSignal" }
    },
    "sources": {
      "type": "array",
      "items": { "$ref": "#/$defs/sourceRef" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "sourceRef": {
      "type": "object",
      "required": ["source_id", "path", "kind", "hash", "hash_alg", "span", "observed_at"],
      "properties": {
        "source_id": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "kind": { "type": "string", "minLength": 1 },
        "hash": { "type": "string", "pattern": "^[0-9a-f]{16}$" },
        "hash_alg": { "type": "string", "enum": ["fnv1a-64"] },
        "span": { "type": ["string", "null"] },
        "observed_at": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "compiledFact": {
      "type": "object",
      "required": [
        "id",
        "statement",
        "confidence",
        "objective_relevance",
        "novelty_gain",
        "needs_raw_drilldown",
        "source_ids"
      ],
      "properties": {
        "id": { "type": "string" },
        "statement": { "type": "string" },
        "confidence": { "type": "number" },
        "objective_relevance": { "type": "number" },
        "novelty_gain": { "type": "number" },
        "needs_raw_drilldown": { "type": "boolean" },
        "source_ids": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "source_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/sourceRef" }
        }
      },
      "additionalProperties": false
    },
    "evidenceRecord": {
      "type": "object",
      "required": ["id", "kind", "summary", "source_ids", "observed_at"],
      "properties": {
        "id": { "type": "string" },
        "kind": { "type": "string" },
        "summary": { "type": "string" },
        "source_ids": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "source_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/sourceRef" }
        },
        "observed_at": { "type": "string" },
        "agent_id": { "type": "string" },
        "lane": { "type": "string" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "rationale": { "type": "string" },
        "diff_ref": { "type": "string" },
        "span_before": { "type": "string" },
        "span_after": { "type": "string" }
      },
      "additionalProperties": false
    },
    "hypothesis": {
      "type": "object",
      "required": ["id", "statement", "confidence", "verifier_score", "source_ids"],
      "properties": {
        "id": { "type": "string" },
        "statement": { "type": "string" },
        "confidence": { "type": "number" },
        "verifier_score": { "type": ["number", "null"] },
        "source_ids": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "source_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/sourceRef" }
        }
      },
      "additionalProperties": false
    },
    "contradiction": {
      "type": "object",
      "required": ["id", "summary", "conflicting_item_ids", "severity", "source_ids"],
      "properties": {
        "id": { "type": "string" },
        "summary": { "type": "string" },
        "conflicting_item_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "severity": { "type": "string" },
        "source_ids": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "source_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/sourceRef" }
        }
      },
      "additionalProperties": false
    },
    "recurringFailurePattern": {
      "type": "object",
      "required": ["id", "summary", "count", "last_seen_at", "impact", "source_ids"],
      "properties": {
        "id": { "type": "string" },
        "summary": { "type": "string" },
        "count": { "type": "integer", "minimum": 0 },
        "last_seen_at": { "type": "string" },
        "impact": { "type": "string" },
        "source_ids": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        }
      },
      "additionalProperties": false
    },
    "candidateAction": {
      "type": "object",
      "required": [
        "id",
        "title",
        "rationale",
        "actionability_score",
        "decision_dependency_ids",
        "source_ids"
      ],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "rationale": { "type": "string" },
        "actionability_score": { "type": "number" },
        "decision_dependency_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "source_ids": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        }
      },
      "additionalProperties": false
    },
    "verifierFinding": {
      "type": "object",
      "required": ["id", "summary", "status", "verifier_score", "source_ids"],
      "properties": {
        "id": { "type": "string" },
        "summary": { "type": "string" },
        "status": { "type": "string" },
        "verifier_score": { "type": "number" },
        "source_ids": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "source_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/sourceRef" }
        },
        "agent_id": { "type": "string" },
        "lane": { "type": "string" },
        "closure_reason": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "haltSignal": {
      "type": "object",
      "required": ["id", "kind", "contribution", "rationale", "source_ids"],
      "properties": {
        "id": { "type": "string" },
        "kind": { "type": "string" },
        "contribution": { "type": "number" },
        "rationale": { "type": "string" },
        "source_ids": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        }
      },
      "additionalProperties": false
    }
  }
}
